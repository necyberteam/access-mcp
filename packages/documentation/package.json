{
  "name": "@access-mcp/documentation",
  "version": "0.1.0",
  "description": "MCP server for ACCESS-CI documentation retrieval (RAG)",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "access-mcp-documentation": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:all": "vitest run && vitest run --config vitest.integration.config.ts",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": ["mcp", "access-ci", "documentation", "rag"],
  "author": "ACCESS-CI",
  "license": "MIT",
  "dependencies": {
    "@access-mcp/shared": "^0.9.0",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "axios": "^1.7.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  }
}
