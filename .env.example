# Environment variables for MCP servers
# Copy this file to .env and fill in your API keys

# Software Discovery Service API key (required for software-discovery server)
SDS_API_KEY=your-sds-api-key-here

# XDMoD API token (optional for xdmod-data server)
XDMOD_API_TOKEN=your-xdmod-api-token-here

# ACCESS AI / UKY documentation RAG key (server-side secret for the
# documentation server). Sent upstream as X-API-KEY to UKY's retrieve-docs
# endpoint, which currently returns 401 without it. Leave unset and the
# server simply sends no auth header.
ACCESS_AI_API_KEY=your-access-ai-api-key-here

# MCP service endpoints for inter-server communication (Docker deployment)
ACCESS_MCP_SERVICES=nsf-awards=http://localhost:3007

# Drupal account with the mcp_bot role (announcements server, news content CRUD).
DRUPAL_API_URL=https://support.access-ci.org
DRUPAL_USERNAME=your-mcp_bot-account
DRUPAL_PASSWORD=your-mcp_bot-password

# Drupal account with the mcp_service role (allocations get_rp_account, which
# uses the X-Acting-User header). Must be a separate account from the mcp_bot one.
MCP_SERVICE_DRUPAL_USERNAME=your-mcp_service-account
MCP_SERVICE_DRUPAL_PASSWORD=your-mcp_service-password

# OpenTelemetry - Honeycomb
# Get your API key from: Honeycomb > Team Settings > API Keys
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=https://api.honeycomb.io
OTEL_EXPORTER_OTLP_HEADERS=x-honeycomb-team=your-honeycomb-api-key
HONEYCOMB_DATASET=access-ci

# MCP usage logging (analytics over direct MCP traffic). Every tool call is
# logged best-effort to the mcp_usage schema. Logging is ON by default: the
# prod compose defaults MCP_USAGE_DB_URL to the dedicated `mcp-usage-db`
# service (an isolated Postgres on mcp-network only — NOT the agent's DB, so
# the MCP servers gain no reachability to the agent stack). To disable, set
# MCP_USAGE_DB_URL to an empty string. To use a different store, set the full
# URL here.
#
# NOTE: the default password is `mcpusage` in BOTH the mcp-usage-db service
# (MCP_USAGE_DB_PASSWORD) and the connection-string default. If you change the
# DB password, you MUST also set MCP_USAGE_DB_URL explicitly, or the servers
# will silently fail to connect (best-effort logging swallows the error).
# MCP_USAGE_DB_PASSWORD=change-me-and-set-MCP_USAGE_DB_URL-too
# MCP_USAGE_DB_URL=postgresql://mcp_usage_app:change-me@mcp-usage-db:5432/mcp_usage