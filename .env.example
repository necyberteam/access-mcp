# Environment variables for MCP servers
# Copy this file to .env and fill in your API keys

# Software Discovery Service API key (required for software-discovery server)
SDS_API_KEY=your-sds-api-key-here

# XDMoD API token (optional for xdmod-data server)
XDMOD_API_TOKEN=your-xdmod-api-token-here

# MCP service endpoints for inter-server communication (Docker deployment)
ACCESS_MCP_SERVICES=nsf-awards=http://localhost:3007

# OpenTelemetry - Honeycomb
# Get your API key from: Honeycomb > Team Settings > API Keys
OTEL_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=https://api.honeycomb.io
OTEL_EXPORTER_OTLP_HEADERS=x-honeycomb-team=your-honeycomb-api-key
HONEYCOMB_DATASET=access-ci

# MCP usage logging (analytics over direct MCP traffic). When set, every tool
# call is logged best-effort to the mcp_usage schema at this URL. Unset = off.
# Day one this points at the agent's Postgres (the langgraph DB on mcp-network).
MCP_USAGE_DB_URL=postgresql://mcp_usage_app:PASSWORD@postgres:5432/langgraph