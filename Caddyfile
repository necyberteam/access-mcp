mcp.access-ci.org {
    handle /compute-resources/* {
        uri strip_prefix /compute-resources
        reverse_proxy mcp-compute-resources:3000 {
            flush_interval -1
            transport http {
                read_timeout 0
            }
        }
    }

    handle /system-status/* {
        uri strip_prefix /system-status
        reverse_proxy mcp-system-status:3000 {
            flush_interval -1
            transport http {
                read_timeout 0
            }
        }
    }

    handle /software-discovery/* {
        uri strip_prefix /software-discovery
        reverse_proxy mcp-software-discovery:3000 {
            flush_interval -1
            transport http {
                read_timeout 0
            }
        }
    }

    handle /xdmod/* {
        uri strip_prefix /xdmod
        reverse_proxy mcp-xdmod:3000 {
            flush_interval -1
            transport http {
                read_timeout 0
            }
        }
    }

    handle /allocations/* {
        uri strip_prefix /allocations
        reverse_proxy mcp-allocations:3000 {
            flush_interval -1
            transport http {
                read_timeout 0
            }
        }
    }

    handle /nsf-awards/* {
        uri strip_prefix /nsf-awards
        reverse_proxy mcp-nsf-awards:3000 {
            flush_interval -1
            transport http {
                read_timeout 0
            }
        }
    }

    handle /xdmod-data/* {
        uri strip_prefix /xdmod-data
        reverse_proxy mcp-xdmod-data:3000 {
            flush_interval -1
            transport http {
                read_timeout 0
            }
        }
    }

    handle /announcements/* {
        uri strip_prefix /announcements
        reverse_proxy mcp-announcements:3000 {
            flush_interval -1
            transport http {
                read_timeout 0
            }
        }
    }

    handle /events/* {
        uri strip_prefix /events
        reverse_proxy mcp-events:3000 {
            flush_interval -1
            transport http {
                read_timeout 0
            }
        }
    }

    handle /affinity-groups/* {
        uri strip_prefix /affinity-groups
        reverse_proxy mcp-affinity-groups:3000 {
            flush_interval -1
            transport http {
                read_timeout 0
            }
        }
    }

    handle /jsm/* {
        uri strip_prefix /jsm
        reverse_proxy mcp-jsm:3000 {
            flush_interval -1
            transport http {
                read_timeout 0
            }
        }
    }

    @docs-no-slash path /docs
    redir @docs-no-slash /docs/ permanent

    handle /docs/* {
        uri strip_prefix /docs
        reverse_proxy https://access-mcp.netlify.app {
            header_up Host access-mcp.netlify.app
        }
    }

    handle / {
        respond "ACCESS-CI MCP Servers

Documentation: https://mcp.access-ci.org/docs/

Available MCP endpoints:
- /compute-resources/sse
- /system-status/sse
- /software-discovery/sse
- /xdmod/sse
- /allocations/sse
- /nsf-awards/sse
- /xdmod-data/sse
- /announcements/sse
- /events/sse
- /affinity-groups/sse
- /jsm/sse
" 200
    }
}

ask.cnct.ci {
    reverse_proxy host.docker.internal:8080 {
        header_up Host {host}
        header_up X-Real-IP {remote_host}
        header_up X-Forwarded-For {remote_host}
        header_up X-Forwarded-Proto {scheme}
    }
}
